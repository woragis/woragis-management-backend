# Postgres
POSTGRES_USER=woragis
POSTGRES_PASSWORD=woragis
POSTGRES_DB=woragis
DATABASE_URL=postgres://woragis:woragis@127.0.0.1:15432/woragis?sslmode=disable

# API
HTTP_ADDR=:8080
MIGRATIONS_DIR=/migrations
SKIP_SQL_MIGRATIONS=0

# Auth (admin routes)
ADMIN_API_KEY=dev-only-change-me

# Agent worker → /v1/internal/agent/*
AGENT_API_KEY=change-me-agent-key

# Redis (agent personality cache; optional in local dev)
REDIS_URL=redis://127.0.0.1:6379/0

# Secrets encryption (32+ chars)
SECRETS_ENCRYPTION_KEY=dev-only-32-char-secret-key!!

# Media storage: local | s3 (Railway bucket)
MEDIA_STORAGE=local
MEDIA_STORAGE_DIR=./data/media
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:8080/v1/public/media

# Railway bucket (S3-compatible) — auto-detected when set without MEDIA_STORAGE
# MEDIA_STORAGE=s3
# AWS_ENDPOINT_URL=https://storage.railway.app
# AWS_DEFAULT_REGION=auto
# AWS_S3_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=tid_xxx
# AWS_SECRET_ACCESS_KEY=tsec_xxx

# CORS — no quotes in Railway/Vercel values
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://management.woragis.me,https://www.woragis.me
CORS_ALLOW_CREDENTIALS=1
METRICS_ENABLED=1

# Creatives API (thumbnail generation) — creatives default port in docker is 8080; use another port if management also uses 8080
CREATIVES_API_URL=http://127.0.0.1:8081
CREATIVES_API_KEY=management:change-me-management-key
MANAGEMENT_WEBHOOK_URL=http://127.0.0.1:8080/v1/webhooks/creatives
CONTENT_THUMBNAIL_DEFAULT_SIZE=1280x720

# WhatsApp worker
WORKER_API_KEY=change-me-worker-key
WHATSAPP_WORKER_URL=http://127.0.0.1:3001
WHATSAPP_POSTGRES_USER=woragis
WHATSAPP_POSTGRES_PASSWORD=woragis
WHATSAPP_POSTGRES_DB=whatsapp
WHATSAPP_DATABASE_URL=postgres://woragis:woragis@127.0.0.1:5433/whatsapp?sslmode=disable
WHATSAPP_TZ=America/Sao_Paulo
AGENT_WORKER_URL=http://127.0.0.1:3002
CHANNEL_WORKER_KEY=change-me-channel-key

# Scheduler worker
POLL_INTERVAL_MS=60000

# Agent worker (brain — OpenAI optional until configured)
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WORKER_URL=http://127.0.0.1:3003

# Twilio (optional — voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
