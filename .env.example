# Postgres
POSTGRES_USER=woragis
POSTGRES_PASSWORD=woragis
POSTGRES_DB=woragis
DATABASE_URL=postgres://woragis:woragis@127.0.0.1:15432/woragis?sslmode=disable

# API
HTTP_ADDR=:8080
MIGRATIONS_DIR=/migrations
SKIP_SQL_MIGRATIONS=0

# Auth (admin routes)
ADMIN_API_KEY=dev-only-change-me

# Secrets encryption (32-byte key, base64-encoded)
SECRETS_ENCRYPTION_KEY=

# Media storage
MEDIA_STORAGE_DIR=./data/media
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:8080/v1/public/media

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=1
METRICS_ENABLED=1
